# Google Places API
GOOGLE_PLACES_API_KEY=

# Companies House API (free, register at developer.company-information.service.gov.uk)
COMPANIES_HOUSE_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Email — leave blank to use Ethereal (fake inbox, good for testing)
# Set SMTP_HOST etc. when ready for real sending (e.g. Amazon SES)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=hello@alreadydone.co.uk
FROM_NAME=Rougvie

# Resend webhook signing secret — from Resend dashboard → Webhooks → signing secret
# Also add to Cloudflare Pages env vars for the webhook function to use
RESEND_WEBHOOK_SECRET=

# PostHog (website analytics for customer sites and monthly reports)
# EU cloud recommended for UK/GDPR — set POSTHOG_HOST accordingly
POSTHOG_HOST=https://eu.i.posthog.com
# Project API key (phc_xxx) — embedded in every customer site JS snippet, safe to expose
POSTHOG_INGEST_KEY=
# Project ID (numeric) — from the PostHog project URL
POSTHOG_PROJECT_ID=
# Personal API key — for server-side report queries (PostHog Settings > Personal API keys)
POSTHOG_API_KEY=

# Pipeline config
MAX_RESULTS_PER_QUERY=60
FOLLOW_UP_DELAY_DAYS=5
NO_REPLY_TIMEOUT_DAYS=14
BASE_PRICE_GBP=99
