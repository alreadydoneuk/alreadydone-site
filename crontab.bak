# System health
0 7 * * * /home/brantley/homelab_daily_health.sh >> /home/brantley/homelab_reports/cron.log 2>&1

# ── Already Done pipeline ────────────────────────────────────────────────────
# 2:00am: Main pipeline — reply monitor + follow-up + research + site builder
# Pipeline script handles its own .env sourcing and Slack notifications.
0 2 * * * /home/brantley/alreadydone/scripts/run-pipeline-cron.sh >> /home/brantley/alreadydone/logs/cron-errors.log 2>&1

# ── Enrichment: Ghost + Dark cohorts, WHOIS on Dark, Serper email search ────
# Runs 3x/day during business hours. 50 businesses/run = 150/day.
# cd ensures dotenv finds .env in the project root.
0 9  * * * cd /home/brantley/alreadydone && /home/brantley/.nvm/versions/node/v24.13.0/bin/node scripts/run-enrichment.js  >> /home/brantley/alreadydone/logs/enrichment.log 2>&1
0 13 * * * cd /home/brantley/alreadydone && /home/brantley/.nvm/versions/node/v24.13.0/bin/node scripts/run-enrichment.js  >> /home/brantley/alreadydone/logs/enrichment.log 2>&1
0 16 * * * cd /home/brantley/alreadydone && /home/brantley/.nvm/versions/node/v24.13.0/bin/node scripts/run-enrichment.js  >> /home/brantley/alreadydone/logs/enrichment.log 2>&1

# ── Domain expiry: flags recently lapsed and imminent-expiry Dark businesses ─
# Runs after overnight enrichment has collected WHOIS data.
30 8 * * * cd /home/brantley/alreadydone && /home/brantley/.nvm/versions/node/v24.13.0/bin/node scripts/run-domain-expiry.js >> /home/brantley/alreadydone/logs/domain-expiry.log 2>&1

# ── Outreach: Mon–Fri, business hours only, capped at 4pm ──────────────────
# Business hours guard is inside the agent — safe to run on the hour.
# No 5pm run: emails arriving at 4-5pm get read next morning at best.
0 9,11,13,15 * * 1-5 cd /home/brantley/alreadydone && /home/brantley/.nvm/versions/node/v24.13.0/bin/node scripts/run-outreach.js >> /home/brantley/alreadydone/logs/outreach.log 2>&1

